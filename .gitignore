# =============================================================================
# DATA & OBSERVABLES (Phase Space)
# =============================================================================
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# Exclude local data copies used for notebook flattening
notebooks/data/

# =============================================================================
# ARTIFACTS & SIGNALS (Experimental Results)
# =============================================================================
# Ignore everything in artifacts by default
artifacts/*

# Explicitly allow the specific results (The Signal)
!artifacts/*.json
!artifacts/*.png
!artifacts/*.html
!artifacts/lab02_monthly_hist/
!artifacts/.gitkeep

# =============================================================================
# COURSE-SPECIFIC EXCLUSIONS (Exclusive to Course Repo)
# =============================================================================
# Ignore unified or class-formatted notebooks
notebooks/*_Sanchez*

# Ignore exported reports
notebooks/*.html
notebooks/*.pdf
*.pdf

# =============================================================================
# PYTHON & SYSTEM NOISE (Thermal Fluctuations)
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
venv/
env/
.env

# =============================================================================
# JUPYTER METADATA
# =============================================================================
.ipynb_checkpoints/